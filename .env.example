APP_NAME=ContaEdu
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Railway captura stderr/stdout — no usar "stack" o "single" (escribe en disco)
LOG_CHANNEL=stderr
LOG_LEVEL=error

# ─── Base de datos PostgreSQL ────────────────────────────────────────────────
# DB_HOST: usar la red interna de Railway → postgres.railway.internal
# (más rápido y sin costo de red vs el host público)
DB_CONNECTION=pgsql
DB_HOST=postgres.railway.internal
DB_PORT=5432
DB_DATABASE=railway
DB_USERNAME=postgres
DB_PASSWORD=

# ─── Sesiones en cookie (más simple: no requiere tabla sessions) ─────────────
# Igual que en LaCarta — cookie cifrada del lado del cliente
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

# ─── Caché en BD, colas síncronas (sin worker adicional) ─────────────────────
CACHE_STORE=database
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ─── Path de vistas compiladas (importante en contenedores Railway) ──────────
VIEW_COMPILED_PATH=/app/storage/framework/views

# ─── Archivos temporales de Livewire (uploads CSV) ──────────────────────────
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DIRECTORY=livewire-tmp

# ─── Correo (opcional) ───────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@contaedu.app"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
