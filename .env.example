APP_NAME=ContaEdu
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Base de datos PostgreSQL (Railway provee estas variables) ──────────────
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=railway
DB_USERNAME=postgres
DB_PASSWORD=

# ─── Sesiones y caché en BD (no requiere Redis) ─────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ─── Archivos temporales de Livewire (uploads CSV) ──────────────────────────
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DIRECTORY=livewire-tmp

# ─── Correo (opcional) ───────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@contaedu.app"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
